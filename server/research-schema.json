{
  "type": "object",
  "properties": {
    "executiveBrief": {
      "type": "object",
      "properties": {
        "decision": { "type": "string" },
        "product": { "type": "string" },
        "targetMarket": { "type": "string" },
        "recommendedPath": { "type": "string" },
        "budgetFit": { "type": "string" },
        "topRisks": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "string" }
      },
      "required": ["decision", "product", "targetMarket", "recommendedPath", "budgetFit", "topRisks", "confidence"],
      "additionalProperties": false
    },
    "supplierSearchPlan": {
      "type": "object",
      "properties": {
        "alibabaQueries": { "type": "array", "items": { "type": "string" } },
        "filters": { "type": "array", "items": { "type": "string" } },
        "dataToCapture": { "type": "array", "items": { "type": "string" } },
        "rejectRules": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["alibabaQueries", "filters", "dataToCapture", "rejectRules"],
      "additionalProperties": false
    },
    "agentWorkLog": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "title": { "type": "string" },
          "status": { "type": "string" },
          "result": { "type": "string" },
          "nextAction": { "type": "string" }
        },
        "required": ["key", "title", "status", "result", "nextAction"],
        "additionalProperties": false
      }
    },
    "supplierShortlist": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "supplierName": { "type": "string" },
          "alibabaUrl": { "type": "string" },
          "productMatch": { "type": "string" },
          "moq": { "type": "string" },
          "unitPrice": { "type": "string" },
          "sampleTerms": { "type": "string" },
          "ddpStatus": { "type": "string" },
          "qualityProof": { "type": "string" },
          "certifications": { "type": "string" },
          "score": { "type": "number" },
          "redFlags": { "type": "array", "items": { "type": "string" } },
          "nextAsk": { "type": "string" }
        },
        "required": [
          "supplierName",
          "alibabaUrl",
          "productMatch",
          "moq",
          "unitPrice",
          "sampleTerms",
          "ddpStatus",
          "qualityProof",
          "certifications",
          "score",
          "redFlags",
          "nextAsk"
        ],
        "additionalProperties": false
      }
    },
    "negotiationPlan": {
      "type": "object",
      "properties": {
        "rfqMessage": { "type": "string" },
        "priceNegotiationMessage": { "type": "string" },
        "moqMessage": { "type": "string" },
        "sampleMessage": { "type": "string" },
        "termsToConfirm": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["rfqMessage", "priceNegotiationMessage", "moqMessage", "sampleMessage", "termsToConfirm"],
      "additionalProperties": false
    },
    "supplierOutreachQueue": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "supplierName": { "type": "string" },
          "status": { "type": "string" },
          "messageType": { "type": "string" },
          "message": { "type": "string" },
          "waitingFor": { "type": "string" },
          "needsUserApproval": { "type": "boolean" }
        },
        "required": ["supplierName", "status", "messageType", "message", "waitingFor", "needsUserApproval"],
        "additionalProperties": false
      }
    },
    "ddpPlan": {
      "type": "object",
      "properties": {
        "destination": { "type": "string" },
        "ddpQuestions": { "type": "array", "items": { "type": "string" } },
        "includedChecklist": { "type": "array", "items": { "type": "string" } },
        "redFlags": { "type": "array", "items": { "type": "string" } },
        "fallbackIncoterm": { "type": "string" }
      },
      "required": ["destination", "ddpQuestions", "includedChecklist", "redFlags", "fallbackIncoterm"],
      "additionalProperties": false
    },
    "qualityPlan": {
      "type": "object",
      "properties": {
        "sampleChecklist": { "type": "array", "items": { "type": "string" } },
        "certificationChecks": { "type": "array", "items": { "type": "string" } },
        "inspectionPlan": { "type": "array", "items": { "type": "string" } },
        "packagingChecks": { "type": "array", "items": { "type": "string" } },
        "noGoDefects": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["sampleChecklist", "certificationChecks", "inspectionPlan", "packagingChecks", "noGoDefects"],
      "additionalProperties": false
    },
    "beginnerNextSteps": { "type": "array", "items": { "type": "string" } },
    "limitations": { "type": "array", "items": { "type": "string" } }
  },
  "required": [
    "executiveBrief",
    "supplierSearchPlan",
    "agentWorkLog",
    "supplierShortlist",
    "negotiationPlan",
    "supplierOutreachQueue",
    "ddpPlan",
    "qualityPlan",
    "beginnerNextSteps",
    "limitations"
  ],
  "additionalProperties": false
}
